{
  "name": "project-laser-game",
  "version": "1.0.0",
  "description": "Easter egg from Supercell's Brawl Stars working in desktop browser with arrow key and space bar controls:\r\nhttps://andrei-paraschiv.github.io/project-laser-game/",
  "main": "electron-main.js",
  "devDependencies": {
    "@capacitor/cli": "^8.4.0",
    "@electron/packager": "^18.3.6",
    "electron": "^42.3.3",
    "electron-builder": "^26.0.12",
    "vite": "^8.0.16"
  },
  "dependencies": {
    "@capacitor/android": "^8.4.0",
    "@capacitor/core": "^8.4.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "build:android": "npm run build && npx cap sync android && cd android && gradlew assembleDebug",
    "build:windows": "npx electron-packager . \"Project Laser\" --platform=win32 --arch=x64 --out=dist_electron --overwrite --ignore=\"/\\.vs|/\\.git|/android|/dist$|/dist_electron|/node_modules\""
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/IsraelDXPP/project-laser-game.git"
  },
  "keywords": [],
